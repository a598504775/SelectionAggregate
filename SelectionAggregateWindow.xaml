<Window x:Class="SelectionAggregate.SelectionAggregateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="400"
        Width="380"
        MinHeight="520"
        MinWidth="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Title="Selection Aggregate">

    <Window.Resources>
        <Style TargetType="Border" x:Key="CardBorderStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E3E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionTitleStyle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Background" Value="#F4F4F4"/>
            <Setter Property="BorderBrush" Value="#CFCFCF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F6F8">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,16,16,20">



                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="AGGREGATE"
                                   Grid.Column="0"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <Grid Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="SelectionTextBlock"
                                       FontWeight="Bold"
                                       Text="0 items selected"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,12,0"/>

                            <Button x:Name="FilterButton"
                                    Grid.Column="1"
                                    Content="Filter..."
                                    Click="FilterButton_Click"/>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Parameter"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="#333333"
                                       Margin="0,0,10,0"/>
                            <ComboBox x:Name="ParameterComboBox"
                                      Grid.Row="0"
                                      SelectionChanged="SelectionChanged"
                                      Grid.Column="1" Margin="0,6,0,6" Background="White"/>

                            <TextBlock Text="Operation"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="#333333"
                                       Margin="0,0,10,0"/>

                            <ComboBox x:Name="CalculationComboBox"
                                      Grid.Row="1"
                                      SelectionChanged="SelectionChanged"
                                      Grid.Column="1" Margin="0,6,0,6" Background="White">
                                <ComboBoxItem Content="Sum"/>
                                <ComboBoxItem Content="Average"/>
                                <ComboBoxItem Content="Min"/>
                                <ComboBoxItem Content="Max"/>
                            </ComboBox>
                        </Grid>
                        <Border Height="1"
                                Background="#E0E0E0"
                                Margin="0,10,0,14"/>


                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    BorderBrush="#D8DDE3"
                                    BorderThickness="1"
                                    Background="#FAFBFC"
                                    CornerRadius="6"
                                    MinHeight="32"
                                    Margin="0,0,0,0"
                                    HorizontalAlignment="Stretch" Height="32" Padding="4,0,0,0">
                                <TextBlock x:Name="ResultTextBlock"
                                           Foreground="#444444"
                                           Text="Result will appear here."
                                           TextWrapping="Wrap" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Button x:Name="CalculateButton"
                                    Grid.Column="1"
                                    Content="Calculate"
                                    Height="32"
                                    Width="96"
                                    HorizontalAlignment="Right"
                                    Click="CalculateButton_Click"
                                    FontWeight="Bold"
                                    Background="#2D2D30"
                                    Foreground="White"
                                    BorderBrush="#2D2D30" FontSize="14" VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="HISTORY"
                                       Grid.Column="0"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <Button x:Name="SaveResultButton"
                                Content="Save Result"
                                HorizontalAlignment="Right"
                                Grid.Column="1"
                                IsEnabled="False"/>
                        </Grid>
                        <Border BorderBrush="#D8DDE3"
                                BorderThickness="1"
                                Background="#FAFBFC"
                                CornerRadius="6"
                                Padding="10"
                                MinHeight="80">
                            <TextBlock Text="Saved results will appear here in a future version."
                                       Foreground="#777777"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
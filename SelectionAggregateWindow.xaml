<Window x:Class="SelectionAggregate.SelectionAggregateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="525"
        Width="380"
        MinHeight="525"
        MinWidth="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Title="Selection Aggregate">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/CommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="#F5F6F8">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,16,16,20">
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="AGGREGATE"
                                   Grid.Column="0"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <Grid Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="SelectionTextBlock"
                                       Grid.Column="0"
                                       FontWeight="Bold"
                                       Text="0 items selected"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,12,0"/>

                            <Button x:Name="UndoButton"
                                    Grid.Column="1"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Undo"
                                    Click="UndoButton_Click"
                                    HorizontalAlignment="Right">
                                <Image Source="Resources\undo.png"
                                       Width="18"
                                       Height="18"/>
                            </Button>

                            <Button x:Name="FilterButton"
                                    Grid.Column="2"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Filter"
                                    Click="FilterButton_Click"
                                    HorizontalAlignment="Right">
                                <Image Source="Resources\filter.png"
                                       Width="18"
                                       Height="18"/>
                            </Button>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Parameter"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="#333333"
                                       Margin="0,0,10,0"/>
                            <ComboBox x:Name="ParameterComboBox"
                                      Grid.Row="0"
                                      SelectionChanged="SelectionChanged"
                                      Grid.Column="1"
                                      Style="{StaticResource CleanComboBoxStyle}"/>

                            <TextBlock Text="Operation"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="#333333"
                                       Margin="0,0,10,0"/>

                            <ComboBox x:Name="OperationComboBox"
                                      Grid.Row="1"
                                      SelectionChanged="SelectionChanged"
                                      Grid.Column="1"
                                      Style="{StaticResource CleanComboBoxStyle}">
                                <ComboBoxItem Content="Sum"/>
                                <ComboBoxItem Content="Average"/>
                                <ComboBoxItem Content="Min"/>
                                <ComboBoxItem Content="Max"/>
                            </ComboBox>
                        </Grid>
                        <Border Height="1"
                                Background="#E0E0E0"
                                Margin="0,10,0,14"/>


                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    BorderBrush="#D8DDE3"
                                    BorderThickness="1"
                                    Background="#FAFBFC"
                                    CornerRadius="6"
                                    MinHeight="32"
                                    Margin="0,0,0,0"
                                    HorizontalAlignment="Stretch" Height="32" Padding="4,0,0,0">
                                <TextBlock x:Name="ResultTextBlock"
                                           Foreground="#444444"
                                           Text="Result will appear here."
                                           TextWrapping="Wrap" 
                                           VerticalAlignment="Center"/>
                            </Border>

                            <Button x:Name="CalculateButton"
                                    Grid.Column="1"
                                    Content="Calculate"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="96"
                                    Height="32"
                                    HorizontalAlignment="Right"
                                    Click="CalculateButton_Click"
                                    FontSize="13"
                                    VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </Border>
                <!--Review this-->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,6,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="HISTORY"
                                       Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock 
                                       Text="Right-click a record for more actions."
                                       FontSize="11"
                                       Foreground="#777777"/>
                                </StackPanel>

                            <Button x:Name="SaveResultButton"
                                    Grid.Column="1"
                                    Style="{StaticResource IconButtonStyle}"
                                    Click="SaveResultButton_Click"
                                    HorizontalAlignment="Right"
                                    ToolTip="Save current result">
                                <Image Source="Resources\save.png"
                                       Width="18"
                                       Height="18"/>
                            </Button>
                        </Grid>

                        <Border Style="{StaticResource HistoryBorderStyle}">
                            <StackPanel>
                                <ListBox x:Name="SavedResultsListBox"
                                         Height="110"
                                         BorderBrush="#E3E6EA"
                                         BorderThickness="0"
                                         Background="White"
                                         SelectionChanged="SavedResultsListBox_SelectionChanged">

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="4" 
                                                    Margin="0,0,0,0" 
                                                    CornerRadius="4" 
                                                    PreviewMouseRightButtonDown="SavedResultBorder_PreviewMouseRightButtonDown"
                                                    Background="#F8F9FB">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Rename"
                                                                  Click="RenameSavedResultMenuItem_Click"/>
                                                        <MenuItem Header="Select Elements"
                                                                  Click="SelectSavedResultElementsMenuItem_Click"/>
                                                        <MenuItem Header="Update Element Selection"
                                                                  Click="UpdateSavedResultElementsMenuItem_Click"/>
                                                        <Separator />
                                                        <MenuItem Header="Delete"
                                                                  Click="DeleteSavedResultMenuItem_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               FontSize="11"
                                                               Margin="0,0,0,0"
                                                               Foreground="#222222">            
                                                        <Run Text="{Binding Title}" />
                                                        <Run Text="  -  " />
                                                        <Run Text="{Binding SelectionSummaryText}" />
                                                    </TextBlock>

                                                    <TextBlock FontSize="11"
                                                               Foreground="#444444"
                                                               Margin="0,0,0,0">
                                                        <Run Text="{Binding AggregateOperation}" />
                                                        <Run Text="{Binding AggregateParameter}" />
                                                        <Run Text=": " />
                                                        <Run Text="{Binding AggregateValueText}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
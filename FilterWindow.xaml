<Window x:Class="SelectionAggregate.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SelectionAggregate"
        mc:Ignorable="d"
        Title="FilterWindow" Height="400" Width="240">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock Text="Filter"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,16"/>
            <TextBlock Text="Parameter"/>
            <ComboBox x:Name="FilterParameterComboBox" 
                      Margin="0,4,0,12" 
                      Height="28"/>
            <TextBlock Text="Condition"/>
            <ComboBox x:Name="FilterConditionComboBox" 
                      Margin="0,4,0,12" 
                      Height="28" 
                      SelectionChanged="FilterConditionComboBox_SelectionChanged"/>
            <TextBlock Text="Value"/>
            <TextBox x:Name="FilterValueTextBox" Margin="0,4,0,12" Height="28"/>
            <Button x:Name="ApplyFilterButton"
                    Content="Apply Filter"
                    Height="32"
                    Width="100"
                    Margin="0,8,0,12" 
                    Click="ApplyButton_Click"/>
            <Button 
                    Content="Cancel"
                    Height="32"
                    Width="100"
                    Margin="0,8,0,12"                
                Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

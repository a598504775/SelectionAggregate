<Window x:Class="SelectionAggregate.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SelectionAggregate"
        mc:Ignorable="d"
        Title="Filter" 
        Height="255" 
        Width="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/CommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Background="#F5F6F8">
        <StackPanel Margin="16,16,16,16">
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Parameter" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                        <ComboBox x:Name="FilterParameterComboBox" 
                                  Style="{StaticResource CleanComboBoxStyle}"
                                  Grid.Row="0" 
                                  Grid.Column="1"/>
                        <TextBlock Text="Condition" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                        <ComboBox x:Name="FilterConditionComboBox" 
                                  Style="{StaticResource CleanComboBoxStyle}"
                                  SelectionChanged="FilterConditionComboBox_SelectionChanged" 
                                  Grid.Row="1" Grid.Column="1" 
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Value" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                        <TextBox x:Name="FilterValueTextBox" 
                                 Height="24" Grid.Row="2" 
                                 Grid.Column="1" 
                                 VerticalAlignment="Center"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="42"/>
                        </Grid.RowDefinitions>
                        <Button x:Name="ApplyFilterButton"
                                Content="Apply"
                                Grid.Column="2" 
                                Grid.Row="0"
                                Height="24"
                                Style="{StaticResource BaseButtonStyle}"
                                Click="ApplyButton_Click" 
                                HorizontalAlignment="Right"/>
                        <Button Content="Cancel"
                                Height="24"
                                Grid.Column="0"
                                Grid.Row="0"
                                Width="64"     
                                Style="{StaticResource BaseButtonStyle}"
                                Click="CancelButton_Click" 
                                HorizontalAlignment="Left"/>
                    </Grid>



                </StackPanel>

            </Border>

        </StackPanel>
    </Grid>
</Window>
